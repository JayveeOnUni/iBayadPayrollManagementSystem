<%- include('partials/header', { title: 'Job Desk', activeMenu: 'job-desk', activePage: 'job-desk' }) %>

<div class="page-header">
  <h1 class="page-title">Job Desk</h1>
</div>

<div class="content-section">
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;">
    <% [
      { label:'Allowance',  icon:'dollar-sign', href:'/job-desk/allowance',  desc:'Manage employee allowances and benefits', color:'var(--info)' },
      { label:'Employee',   icon:'users',       href:'/employees',           desc:'View and manage all employees',            color:'var(--primary)' },
      { label:'Attendance', icon:'clock',       href:'/attendance/daily-log',desc:'Track daily attendance records',           color:'var(--success-main)' },
      { label:'Leave',      icon:'calendar',    href:'/leave/status',        desc:'Review and approve leave requests',        color:'var(--warning-main)' },
      { label:'Payslip',    icon:'file-text',   href:'/job-desk/slip',       desc:'Generate and view payslips',               color:'var(--danger-main)' },
      { label:'Contacts',   icon:'phone',       href:'/job-desk/contacts',   desc:'Employee directory and contacts',          color:'#8B5CF6' },
    ].forEach(item => { %>
    <a href="<%= item.href %>" style="text-decoration:none;">
      <div class="card" style="padding:24px;cursor:pointer;transition:box-shadow .15s;border:1px solid transparent;" onmouseover="this.style.boxShadow='0 4px 20px rgba(0,0,0,.08)';this.style.borderColor='var(--n40)';" onmouseout="this.style.boxShadow='';this.style.borderColor='transparent';">
        <div style="width:44px;height:44px;border-radius:10px;background:<%= item.color %>20;display:flex;align-items:center;justify-content:center;margin-bottom:12px;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="<%= item.color %>" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <% if (item.icon === 'dollar-sign') { %><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            <% } else if (item.icon === 'users') { %><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            <% } else if (item.icon === 'clock') { %><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            <% } else if (item.icon === 'calendar') { %><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            <% } else if (item.icon === 'file-text') { %><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
            <% } else if (item.icon === 'phone') { %><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.1a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.44h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            <% } %>
          </svg>
        </div>
        <div style="font-size:15px;font-weight:600;color:var(--n100);margin-bottom:4px;"><%= item.label %></div>
        <div style="font-size:12px;color:var(--n80);"><%= item.desc %></div>
      </div>
    </a>
    <% }) %>
  </div>
</div>

<%- include('partials/footer') %>
