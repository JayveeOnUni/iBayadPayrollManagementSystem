<%- include('partials/header', { title: 'Announcement', activeMenu: 'administration', activePage: 'admin-announcement' }) %>

<div class="page-header">
  <h1 class="page-title">Administration</h1>
  <div class="page-actions">
    <button class="btn btn-primary" onclick="openModal('modal-add')">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add Announcement
    </button>
  </div>
</div>

<div class="content-section">
  <div class="tabs" style="margin-bottom:20px;">
    <a href="/administration/roles"        class="tab-btn">Roles</a>
    <a href="/administration/shift"        class="tab-btn">Shift</a>
    <a href="/administration/department"   class="tab-btn">Department</a>
    <a href="/administration/holiday"      class="tab-btn">Holiday</a>
    <a href="/administration/announcement" class="tab-btn active">Announcement</a>
  </div>

  <div class="card" style="padding:20px 24px;">
    <div class="filters-row">
      <div class="search-box">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" placeholder="Search announcements…" oninput="filterTable('ann-q', 'ann-table')" id="ann-q">
      </div>
    </div>
    <div class="table-wrap">
      <table class="table-lg" id="ann-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Title</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Description</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% announcements.forEach((a, i) => { %>
          <tr>
            <td style="color:var(--n80);"><%= i + 1 %></td>
            <td style="font-weight:500;"><%= a.title %></td>
            <td class="text-muted"><%= a.start_date %></td>
            <td class="text-muted"><%= a.end_date %></td>
            <td class="text-muted" style="max-width:260px;"><%= a.description %></td>
            <td>
              <div class="actions-col">
                <button class="btn btn-outline btn-sm" onclick='editAnn(<%= JSON.stringify(a) %>)'>Edit</button>
                <form id="del-ann-<%= a.id %>" action="/administration/announcement/<%= a.id %>?_method=DELETE" method="POST" style="display:inline;">
                  <button type="button" class="btn btn-sm" style="background:var(--danger-surface);color:var(--danger-main);" onclick="confirmDelete('del-ann-<%= a.id %>')">Delete</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
          <% if (announcements.length === 0) { %>
          <tr><td colspan="6" style="text-align:center;color:var(--n80);padding:32px;">No announcements yet.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add Modal -->
<div class="modal-overlay" id="modal-add">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Add Announcement</div>
      <button class="modal-close" onclick="closeModal('modal-add')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form action="/administration/announcement" method="POST">
      <div class="modal-body">
        <div class="form-grid">
          <div class="form-group full">
            <label class="form-label">Title *</label>
            <input class="form-input" name="title" required placeholder="Announcement title">
          </div>
          <div class="form-group">
            <label class="form-label">Start Date</label>
            <input class="form-input" type="datetime-local" name="start_date">
          </div>
          <div class="form-group">
            <label class="form-label">End Date</label>
            <input class="form-input" type="datetime-local" name="end_date">
          </div>
          <div class="form-group full">
            <label class="form-label">Description</label>
            <textarea class="form-input" name="description" placeholder="Write announcement details…"></textarea>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('modal-add')">Cancel</button>
        <button type="submit" class="btn btn-primary">Save</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal-overlay" id="modal-edit">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Edit Announcement</div>
      <button class="modal-close" onclick="closeModal('modal-edit')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form id="edit-ann-form" action="" method="POST">
      <input type="hidden" name="_method" value="PUT">
      <div class="modal-body">
        <div class="form-grid">
          <div class="form-group full">
            <label class="form-label">Title *</label>
            <input class="form-input" name="title" id="edit-title" required>
          </div>
          <div class="form-group">
            <label class="form-label">Start Date</label>
            <input class="form-input" name="start_date" id="edit-start">
          </div>
          <div class="form-group">
            <label class="form-label">End Date</label>
            <input class="form-input" name="end_date" id="edit-end">
          </div>
          <div class="form-group full">
            <label class="form-label">Description</label>
            <textarea class="form-input" name="description" id="edit-desc"></textarea>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('modal-edit')">Cancel</button>
        <button type="submit" class="btn btn-primary">Update</button>
      </div>
    </form>
  </div>
</div>

<script>
function editAnn(a) {
  document.getElementById('edit-ann-form').action = '/administration/announcement/' + a.id;
  document.getElementById('edit-title').value = a.title;
  document.getElementById('edit-start').value = a.start_date || '';
  document.getElementById('edit-end').value   = a.end_date   || '';
  document.getElementById('edit-desc').value  = a.description || '';
  openModal('modal-edit');
}
</script>

<%- include('partials/footer') %>
