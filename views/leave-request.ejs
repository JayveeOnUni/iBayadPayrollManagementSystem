<%- include('partials/header', { title: 'Leave Request', activeMenu: 'leave', activePage: 'leave-request' }) %>

<div class="page-header">
  <h1 class="page-title">Leave</h1>
  <div class="page-actions">
    <button class="btn btn-primary" onclick="openModal('modal-add-leave')">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      File Leave
    </button>
  </div>
</div>

<div class="content-section">
  <div class="tabs">
    <a href="/leave/status"   class="tab-btn">Status</a>
    <a href="/leave/request"  class="tab-btn active">Request</a>
    <a href="/leave/calendar" class="tab-btn">Calendar</a>
    <a href="/leave/summary"  class="tab-btn">Summary</a>
  </div>

  <div class="card" style="padding:20px 24px;">
    <div class="section-bar">
      <div class="section-title">Pending Leave Requests</div>
    </div>
    <div class="table-wrap">
      <table class="table-lg">
        <thead>
          <tr>
            <th>Employee</th>
            <th>Leave Type</th>
            <th>From</th>
            <th>To</th>
            <th>Days</th>
            <th>Reason</th>
            <th>Submitted</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% pendingLeaves.forEach(l => { %>
          <tr>
            <td style="font-weight:500;"><%= l.employee_name %></td>
            <td><%= l.leave_type %></td>
            <td class="text-muted"><%= l.start_date %></td>
            <td class="text-muted"><%= l.end_date %></td>
            <td style="text-align:center;"><%= l.days %></td>
            <td class="text-muted"><%= l.reason || '—' %></td>
            <td class="text-muted" style="font-size:12px;"><%= l.created_at ? l.created_at.substring(0,10) : '' %></td>
            <td>
              <div class="actions-col">
                <form action="/leave/<%= l.id %>/approve" method="POST">
                  <button type="submit" class="btn btn-sm btn-success">Approve</button>
                </form>
                <form action="/leave/<%= l.id %>/reject" method="POST">
                  <button type="submit" class="btn btn-sm btn-danger">Reject</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
          <% if (pendingLeaves.length === 0) { %>
          <tr><td colspan="8" style="text-align:center;color:var(--n80);padding:32px;">No pending leave requests.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add Leave Modal (reused) -->
<div class="modal-overlay" id="modal-add-leave">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">File Leave Request</div>
      <button class="modal-close" onclick="closeModal('modal-add-leave')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form action="/leave" method="POST">
      <div class="modal-body">
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Employee *</label>
            <select class="form-input form-select" name="employee_id" required style="background-position:right 8px center;">
              <% employees.forEach(e => { %>
              <option value="<%= e.id %>"><%= e.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Leave Type *</label>
            <select class="form-input form-select" name="leave_type" required style="background-position:right 8px center;">
              <option>Sick Leave</option>
              <option>Vacation Leave</option>
              <option>Emergency Leave</option>
              <option>Maternity Leave</option>
              <option>Paternity Leave</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Start Date *</label>
            <input class="form-input" type="date" name="start_date" required>
          </div>
          <div class="form-group">
            <label class="form-label">End Date *</label>
            <input class="form-input" type="date" name="end_date" required>
          </div>
          <div class="form-group">
            <label class="form-label">Number of Days</label>
            <input class="form-input" type="number" name="days" min="1" value="1">
          </div>
          <div class="form-group full">
            <label class="form-label">Reason</label>
            <textarea class="form-input" name="reason" placeholder="Briefly describe your reason…"></textarea>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('modal-add-leave')">Cancel</button>
        <button type="submit" class="btn btn-primary">Submit</button>
      </div>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
