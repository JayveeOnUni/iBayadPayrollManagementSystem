<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'IBayad' %> — IBayad HR</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/feather-icons@4.29.1/dist/feather.min.js"></script>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

<%
  const _am  = typeof activeMenu !== 'undefined' ? activeMenu : '';
  const _ap  = typeof activePage !== 'undefined' ? activePage : '';
%>

<!-- ── TOP HEADER ─────────────────────────────────────────── -->
<header class="header">
  <a href="/" class="header-logo">
    <span class="logo-icon">
      <svg width="28" height="20" viewBox="0 0 28 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <ellipse cx="9" cy="10" rx="9" ry="9" fill="#212143"/>
        <ellipse cx="19" cy="10" rx="9" ry="9" fill="#146ADC" fill-opacity="0.75"/>
      </svg>
    </span>
    <span class="header-logo-text">IBayad</span>
  </a>
  <div class="header-actions">
    <a href="#" class="header-lang">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      EN
    </a>
    <button class="header-icon-btn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
    </button>
    <div class="header-avatar">JS</div>
  </div>
</header>

<!-- ── SIDEBAR ────────────────────────────────────────────── -->
<aside class="sidebar">
  <nav class="sidebar-nav">

    <!-- Dashboard -->
    <div class="nav-item">
      <a href="/" class="nav-link <%= _am === 'dashboard' ? 'active' : '' %>">
        <span class="nav-link-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span>
        <span class="nav-link-label">Dashboard</span>
      </a>
    </div>

    <!-- Job Desk -->
    <div class="nav-item">
      <a href="/job-desk" class="nav-link <%= _am === 'job-desk' ? 'active' : '' %>">
        <span class="nav-link-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg></span>
        <span class="nav-link-label">Job Desk</span>
      </a>
    </div>

    <!-- Employee -->
    <div class="nav-item <%= _am === 'employees' ? 'open' : '' %>">
      <button class="nav-link <%= _am === 'employees' ? 'active' : '' %>" onclick="toggleNav(this)">
        <span class="nav-link-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
        <span class="nav-link-label">Employee</span>
        <svg class="nav-link-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="nav-submenu">
        <a href="/employees"             class="nav-sublink <%= _ap === 'employees-all' ? 'active' : '' %>">All Employee</a>
        <a href="/employees/appointment" class="nav-sublink <%= _ap === 'employees-appointment' ? 'active' : '' %>">Appointment</a>
      </div>
    </div>

    <!-- Leave -->
    <div class="nav-item <%= _am === 'leave' ? 'open' : '' %>">
      <button class="nav-link <%= _am === 'leave' ? 'active' : '' %>" onclick="toggleNav(this)">
        <span class="nav-link-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span>
        <span class="nav-link-label">Leave</span>
        <svg class="nav-link-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="nav-submenu">
        <a href="/leave/status"   class="nav-sublink <%= _ap === 'leave-status' ? 'active' : '' %>">Status</a>
        <a href="/leave/request"  class="nav-sublink <%= _ap === 'leave-request' ? 'active' : '' %>">Request</a>
        <a href="/leave/calendar" class="nav-sublink <%= _ap === 'leave-calendar' ? 'active' : '' %>">Calendar</a>
        <a href="/leave/summary"  class="nav-sublink <%= _ap === 'leave-summary' ? 'active' : '' %>">Summary</a>
      </div>
    </div>

    <!-- Attendance -->
    <div class="nav-item <%= _am === 'attendance' ? 'open' : '' %>">
      <button class="nav-link <%= _am === 'attendance' ? 'active' : '' %>" onclick="toggleNav(this)">
        <span class="nav-link-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
        <span class="nav-link-label">Attendance</span>
        <svg class="nav-link-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="nav-submenu">
        <a href="/attendance/daily-log" class="nav-sublink <%= _ap === 'attendance-daily' ? 'active' : '' %>">Daily Log</a>
        <a href="/attendance/request"   class="nav-sublink <%= _ap === 'attendance-request' ? 'active' : '' %>">Request</a>
        <a href="/attendance/details"   class="nav-sublink <%= _ap === 'attendance-details' ? 'active' : '' %>">Details</a>
        <a href="/attendance/summary"   class="nav-sublink <%= _ap === 'attendance-summary' ? 'active' : '' %>">Summary</a>
      </div>
    </div>

    <!-- Administration -->
    <div class="nav-item <%= _am === 'administration' ? 'open' : '' %>">
      <button class="nav-link <%= _am === 'administration' ? 'active' : '' %>" onclick="toggleNav(this)">
        <span class="nav-link-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg></span>
        <span class="nav-link-label">Administration</span>
        <svg class="nav-link-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="nav-submenu">
        <a href="/administration/roles"        class="nav-sublink <%= _ap === 'admin-roles' ? 'active' : '' %>">Roles</a>
        <a href="/administration/shift"        class="nav-sublink <%= _ap === 'admin-shift' ? 'active' : '' %>">Shift</a>
        <a href="/administration/department"   class="nav-sublink <%= _ap === 'admin-department' ? 'active' : '' %>">Department</a>
        <a href="/administration/holiday"      class="nav-sublink <%= _ap === 'admin-holiday' ? 'active' : '' %>">Holiday</a>
        <a href="/administration/announcement" class="nav-sublink <%= _ap === 'admin-announcement' ? 'active' : '' %>">Announcement</a>
      </div>
    </div>

    <!-- Setting -->
    <div class="nav-item <%= _am === 'settings' ? 'open' : '' %>">
      <button class="nav-link <%= _am === 'settings' ? 'active' : '' %>" onclick="toggleNav(this)">
        <span class="nav-link-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></span>
        <span class="nav-link-label">Setting</span>
        <svg class="nav-link-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="nav-submenu">
        <a href="/settings/general"    class="nav-sublink <%= _ap === 'settings-general' ? 'active' : '' %>">General</a>
        <a href="/settings/leave"      class="nav-sublink <%= _ap === 'settings-leave' ? 'active' : '' %>">Leave</a>
        <a href="/settings/attendance" class="nav-sublink <%= _ap === 'settings-attendance' ? 'active' : '' %>">Attendance</a>
        <a href="/settings/payroll"    class="nav-sublink <%= _ap === 'settings-payroll' ? 'active' : '' %>">Payroll</a>
      </div>
    </div>

  </nav>
</aside>

<!-- ── MAIN CONTENT ────────────────────────────────────────── -->
<main class="main-content">
