<%- include('partials/header', { title: 'Roles', activeMenu: 'administration', activePage: 'admin-roles' }) %>

<div class="page-header">
  <h1 class="page-title">Administration</h1>
  <div class="page-actions">
    <button class="btn btn-primary" onclick="openModal('modal-add')">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add Role
    </button>
  </div>
</div>

<div class="content-section">
  <div class="tabs">
    <a href="/administration/roles"        class="tab-btn active">Roles</a>
    <a href="/administration/shift"        class="tab-btn">Shift</a>
    <a href="/administration/department"   class="tab-btn">Department</a>
    <a href="/administration/holiday"      class="tab-btn">Holiday</a>
    <a href="/administration/announcement" class="tab-btn">Announcement</a>
  </div>

  <div class="card" style="padding:20px 24px;">
    <div class="table-wrap">
      <table class="table-lg">
        <thead>
          <tr><th>#</th><th>Role Name</th><th>Permissions</th><th>Users</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% roles.forEach((r, i) => { %>
          <tr>
            <td style="color:var(--n80);"><%= i+1 %></td>
            <td style="font-weight:500;"><%= r.name %></td>
            <td class="text-muted"><%= r.permissions %></td>
            <td style="text-align:center;"><span class="badge badge-info"><%= r.user_count %></span></td>
            <td>
              <div class="actions-col">
                <button class="btn btn-outline btn-sm" onclick='editRole(<%= JSON.stringify(r) %>)'>Edit</button>
                <form id="del-role-<%= r.id %>" action="/administration/roles/<%= r.id %>?_method=DELETE" method="POST" style="display:inline;">
                  <button type="button" class="btn btn-sm" style="background:var(--danger-surface);color:var(--danger-main);" onclick="confirmDelete('del-role-<%= r.id %>')">Delete</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add Modal -->
<div class="modal-overlay" id="modal-add">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Add Role</div>
      <button class="modal-close" onclick="closeModal('modal-add')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form action="/administration/roles" method="POST">
      <div class="modal-body">
        <div class="form-grid full">
          <div class="form-group">
            <label class="form-label">Role Name *</label>
            <input class="form-input" name="name" required placeholder="e.g. HR Manager">
          </div>
          <div class="form-group">
            <label class="form-label">Permissions</label>
            <input class="form-input" name="permissions" placeholder="e.g. Leave, Attendance">
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('modal-add')">Cancel</button>
        <button type="submit" class="btn btn-primary">Save</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal-overlay" id="modal-edit">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Edit Role</div>
      <button class="modal-close" onclick="closeModal('modal-edit')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form id="edit-form" action="" method="POST">
      <input type="hidden" name="_method" value="PUT">
      <div class="modal-body">
        <div class="form-grid full">
          <div class="form-group">
            <label class="form-label">Role Name *</label>
            <input class="form-input" name="name" id="edit-name" required>
          </div>
          <div class="form-group">
            <label class="form-label">Permissions</label>
            <input class="form-input" name="permissions" id="edit-permissions">
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('modal-edit')">Cancel</button>
        <button type="submit" class="btn btn-primary">Update</button>
      </div>
    </form>
  </div>
</div>

<script>
function editRole(r) {
  document.getElementById('edit-form').action = '/administration/roles/' + r.id;
  document.getElementById('edit-name').value = r.name;
  document.getElementById('edit-permissions').value = r.permissions || '';
  openModal('modal-edit');
}
</script>

<%- include('partials/footer') %>
