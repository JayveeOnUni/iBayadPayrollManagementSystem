<%- include('partials/header', { title: 'Attendance Request', activeMenu: 'attendance', activePage: 'attendance-request' }) %>

<div class="page-header">
  <h1 class="page-title">Attendance</h1>
  <div class="page-actions">
    <button class="btn btn-primary" onclick="openModal('modal-add')">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      New Request
    </button>
  </div>
</div>

<div class="content-section">
  <div class="tabs">
    <a href="/attendance/daily-log" class="tab-btn">Daily Log</a>
    <a href="/attendance/request"   class="tab-btn active">Request</a>
    <a href="/attendance/details"   class="tab-btn">Details</a>
    <a href="/attendance/summary"   class="tab-btn">Summary</a>
  </div>

  <div class="card" style="padding:20px 24px;">
    <div class="section-bar">
      <div class="section-title">Attendance Correction Requests</div>
    </div>
    <div class="table-wrap">
      <table class="table-lg">
        <thead>
          <tr><th>Employee</th><th>Date</th><th>Requested Time In</th><th>Requested Time Out</th><th>Reason</th><th>Status</th></tr>
        </thead>
        <tbody>
          <tr><td colspan="6" style="text-align:center;color:var(--n80);padding:32px;">No correction requests yet.</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="modal-overlay" id="modal-add">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Attendance Correction Request</div>
      <button class="modal-close" onclick="closeModal('modal-add')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <div class="form-grid">
        <div class="form-group full">
          <label class="form-label">Employee</label>
          <select class="form-input form-select" style="background-position:right 8px center;">
            <% employees.forEach(e => { %><option><%= e.name %></option><% }) %>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Date</label>
          <input class="form-input" type="date">
        </div>
        <div class="form-group">
          <label class="form-label">Correct Time In</label>
          <input class="form-input" type="time">
        </div>
        <div class="form-group">
          <label class="form-label">Correct Time Out</label>
          <input class="form-input" type="time">
        </div>
        <div class="form-group full">
          <label class="form-label">Reason</label>
          <textarea class="form-input" placeholder="Reason for correction…"></textarea>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-outline" onclick="closeModal('modal-add')">Cancel</button>
      <button type="button" class="btn btn-primary">Submit</button>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
