<%- include('partials/header', { title: 'Leave Calendar', activeMenu: 'leave', activePage: 'leave-calendar' }) %>

<div class="page-header">
  <h1 class="page-title">Leave</h1>
</div>

<div class="content-section">
  <div class="tabs">
    <a href="/leave/status"   class="tab-btn">Status</a>
    <a href="/leave/request"  class="tab-btn">Request</a>
    <a href="/leave/calendar" class="tab-btn active">Calendar</a>
    <a href="/leave/summary"  class="tab-btn">Summary</a>
  </div>

  <div class="card" style="padding:24px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
      <h2 style="font-size:18px;font-weight:600;color:var(--n100);"><%= monthName %> <%= year %></h2>
      <div style="display:flex;gap:8px;">
        <a href="/leave/calendar?year=<%= prevYear %>&month=<%= prevMonth %>" class="btn btn-outline btn-sm">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          Prev
        </a>
        <a href="/leave/calendar" class="btn btn-outline btn-sm">Today</a>
        <a href="/leave/calendar?year=<%= nextYear %>&month=<%= nextMonth %>" class="btn btn-outline btn-sm">
          Next
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </div>
    </div>

    <div class="cal-grid">
      <% ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].forEach(d => { %>
      <div class="cal-header-cell"><%= d %></div>
      <% }) %>

      <% calDays.forEach(day => { %>
      <div class="cal-cell <%= day.isToday ? 'today' : '' %> <%= day.otherMonth ? 'other-month' : '' %> <%= day.hasLeave ? 'has-leave' : '' %>"
           title="<%= day.leaveInfo || '' %>">
        <%= day.date %>
        <% if (day.hasLeave && !day.isToday) { %>
        <span style="font-size:8px;display:block;color:var(--info);line-height:1;"><%= day.leaveCount %>L</span>
        <% } %>
      </div>
      <% }) %>
    </div>

    <!-- Legend -->
    <div style="display:flex;gap:20px;margin-top:20px;font-size:12px;color:var(--n80);flex-wrap:wrap;">
      <div style="display:flex;align-items:center;gap:6px;">
        <div style="width:10px;height:10px;border-radius:50%;background:var(--primary);"></div> Today
      </div>
      <div style="display:flex;align-items:center;gap:6px;">
        <div style="width:10px;height:10px;border-radius:50%;background:var(--info);"></div> Leave Request
      </div>
    </div>
  </div>

  <!-- Leave list for month -->
  <div style="margin-top:16px;" class="card" style="padding:20px 24px;">
    <div class="card-title">Leave Requests — <%= monthName %></div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Employee</th>
            <th>Type</th>
            <th>From</th>
            <th>To</th>
            <th>Days</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% monthLeaves.forEach(l => { %>
          <tr>
            <td style="font-weight:500;"><%= l.employee_name %></td>
            <td><%= l.leave_type %></td>
            <td class="text-muted"><%= l.start_date %></td>
            <td class="text-muted"><%= l.end_date %></td>
            <td style="text-align:center;"><%= l.days %></td>
            <td>
              <span class="badge <%=
                l.status === 'Approved' ? 'badge-success' :
                l.status === 'Pending'  ? 'badge-warning' : 'badge-danger'
              %>"><%= l.status %></span>
            </td>
          </tr>
          <% }) %>
          <% if (monthLeaves.length === 0) { %>
          <tr><td colspan="6" style="text-align:center;color:var(--n80);padding:24px;">No leave requests this month.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
