<%- include('partials/header', { title: 'All Employees', activeMenu: 'employees', activePage: 'employees-all' }) %>

<div class="page-header">
  <h1 class="page-title">Employee</h1>
  <div class="page-actions">
    <button class="btn btn-primary" onclick="openModal('modal-add-employee')">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add Employee
    </button>
  </div>
</div>

<div class="content-section">
  <!-- Tabs -->
  <div class="tabs">
    <a href="/employees"             class="tab-btn active">All Employee</a>
    <a href="/employees/appointment" class="tab-btn">Appointment</a>
  </div>

  <div class="card" style="padding:20px 24px;">
    <!-- Filters -->
    <div class="filters-row">
      <div class="search-box">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" placeholder="Search employee…" oninput="filterTable('search', 'emp-table')">
      </div>
      <select class="form-select" onchange="filterByStatus(this.value)">
        <option value="">All Status</option>
        <option value="Active">Active</option>
        <option value="Inactive">Inactive</option>
      </select>
      <select class="form-select" onchange="filterByDept(this.value)">
        <option value="">All Department</option>
        <% [...new Set(employees.map(e=>e.department))].forEach(d => { %>
        <option value="<%= d %>"><%= d %></option>
        <% }) %>
      </select>
    </div>

    <!-- Table -->
    <div class="table-wrap">
      <table class="table-lg" id="emp-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Name</th>
            <th>Email</th>
            <th>Department</th>
            <th>Position</th>
            <th>Status</th>
            <th>Start Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% employees.forEach((e, i) => { %>
          <tr data-status="<%= e.status %>" data-dept="<%= e.department %>">
            <td style="color:var(--n80);"><%= i + 1 %></td>
            <td>
              <div style="display:flex;align-items:center;gap:10px;">
                <div style="width:32px;height:32px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0;">
                  <%= e.name.split(' ').map(n=>n[0]).join('').substring(0,2) %>
                </div>
                <span style="font-weight:500;"><%= e.name %></span>
              </div>
            </td>
            <td class="text-muted"><%= e.email %></td>
            <td><%= e.department %></td>
            <td><%= e.position %></td>
            <td>
              <span class="badge <%= e.status === 'Active' ? 'badge-success' : 'badge-neutral' %>">
                <%= e.status %>
              </span>
            </td>
            <td class="text-muted"><%= e.start_date %></td>
            <td>
              <div class="actions-col">
                <button class="btn btn-outline btn-sm" onclick="editEmployee(<%= JSON.stringify(e) %>)">Edit</button>
                <form id="del-emp-<%= e.id %>" action="/employees/<%= e.id %>?_method=DELETE" method="POST" style="display:inline;">
                  <button type="button" class="btn btn-sm" style="background:var(--danger-surface);color:var(--danger-main);" onclick="confirmDelete('del-emp-<%= e.id %>')">Delete</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
          <% if (employees.length === 0) { %>
          <tr><td colspan="8" style="text-align:center;color:var(--n80);padding:32px;">No employees found.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Pagination info -->
    <div class="pagination">
      <span>Showing <%= employees.length %> employees</span>
      <div class="page-controls">
        <span class="page-btn active">1</span>
      </div>
    </div>
  </div>
</div>

<!-- ── Add Employee Modal ──────────────────────────────────── -->
<div class="modal-overlay" id="modal-add-employee">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Add Employee</div>
      <button class="modal-close" onclick="closeModal('modal-add-employee')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form action="/employees" method="POST">
      <div class="modal-body">
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Full Name *</label>
            <input class="form-input" name="name" required placeholder="e.g. Juan Dela Cruz">
          </div>
          <div class="form-group">
            <label class="form-label">Email *</label>
            <input class="form-input" type="email" name="email" required placeholder="juan@ibayad.com">
          </div>
          <div class="form-group">
            <label class="form-label">Department</label>
            <input class="form-input" name="department" placeholder="e.g. Engineering">
          </div>
          <div class="form-group">
            <label class="form-label">Position</label>
            <input class="form-input" name="position" placeholder="e.g. Software Developer">
          </div>
          <div class="form-group">
            <label class="form-label">Start Date</label>
            <input class="form-input" type="date" name="start_date">
          </div>
          <div class="form-group">
            <label class="form-label">Status</label>
            <select class="form-input form-select" name="status" style="background-position:right 8px center;">
              <option value="Active">Active</option>
              <option value="Inactive">Inactive</option>
            </select>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('modal-add-employee')">Cancel</button>
        <button type="submit" class="btn btn-primary">Add Employee</button>
      </div>
    </form>
  </div>
</div>

<!-- ── Edit Employee Modal ─────────────────────────────────── -->
<div class="modal-overlay" id="modal-edit-employee">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Edit Employee</div>
      <button class="modal-close" onclick="closeModal('modal-edit-employee')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form id="edit-emp-form" action="" method="POST">
      <input type="hidden" name="_method" value="PUT">
      <div class="modal-body">
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Full Name *</label>
            <input class="form-input" name="name" id="edit-name" required>
          </div>
          <div class="form-group">
            <label class="form-label">Email *</label>
            <input class="form-input" type="email" name="email" id="edit-email" required>
          </div>
          <div class="form-group">
            <label class="form-label">Department</label>
            <input class="form-input" name="department" id="edit-department">
          </div>
          <div class="form-group">
            <label class="form-label">Position</label>
            <input class="form-input" name="position" id="edit-position">
          </div>
          <div class="form-group">
            <label class="form-label">Start Date</label>
            <input class="form-input" type="date" name="start_date" id="edit-start_date">
          </div>
          <div class="form-group">
            <label class="form-label">Status</label>
            <select class="form-input form-select" name="status" id="edit-status" style="background-position:right 8px center;">
              <option value="Active">Active</option>
              <option value="Inactive">Inactive</option>
            </select>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('modal-edit-employee')">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<script>
function editEmployee(e) {
  document.getElementById('edit-emp-form').action = '/employees/' + e.id;
  document.getElementById('edit-name').value       = e.name;
  document.getElementById('edit-email').value      = e.email;
  document.getElementById('edit-department').value = e.department || '';
  document.getElementById('edit-position').value   = e.position   || '';
  document.getElementById('edit-start_date').value = e.start_date || '';
  document.getElementById('edit-status').value     = e.status     || 'Active';
  openModal('modal-edit-employee');
}
function filterByStatus(v) {
  document.querySelectorAll('#emp-table tbody tr').forEach(row => {
    row.style.display = (!v || row.dataset.status === v) ? '' : 'none';
  });
}
function filterByDept(v) {
  document.querySelectorAll('#emp-table tbody tr').forEach(row => {
    row.style.display = (!v || row.dataset.dept === v) ? '' : 'none';
  });
}
</script>

<%- include('partials/footer') %>
