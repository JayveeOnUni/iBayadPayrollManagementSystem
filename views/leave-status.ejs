<%- include('partials/header', { title: 'Leave Status', activeMenu: 'leave', activePage: 'leave-status' }) %>

<div class="page-header">
  <h1 class="page-title">Leave</h1>
  <div class="page-actions">
    <button class="btn btn-primary" onclick="openModal('modal-add-leave')">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      File Leave
    </button>
  </div>
</div>

<div class="content-section">
  <div class="tabs">
    <a href="/leave/status"   class="tab-btn active">Status</a>
    <a href="/leave/request"  class="tab-btn">Request</a>
    <a href="/leave/calendar" class="tab-btn">Calendar</a>
    <a href="/leave/summary"  class="tab-btn">Summary</a>
  </div>

  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px;">
    <% [
      { label:'Total Allowance', value: 15, color: 'var(--info)' },
      { label:'Leave Taken',     value: leaveTaken,    color: 'var(--danger-main)' },
      { label:'Available',       value: 15 - leaveTaken, color: 'var(--success-main)' },
      { label:'Pending',         value: leavePending,  color: 'var(--warning-main)' },
    ].forEach(s => { %>
    <div class="card" style="padding:16px 20px;">
      <div style="font-size:13px;color:var(--n80);margin-bottom:4px;"><%= s.label %></div>
      <div style="font-size:28px;font-weight:600;color:<%= s.color %>;line-height:1.2;"><%= s.value %></div>
    </div>
    <% }) %>
  </div>

  <div class="card" style="padding:20px 24px;">
    <div class="filters-row">
      <div class="search-box">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" placeholder="Search…" oninput="filterTable('q', 'leave-table')" id="q">
      </div>
      <select class="form-select" onchange="filterLeaveStatus(this.value)">
        <option value="">All Status</option>
        <option value="Approved">Approved</option>
        <option value="Pending">Pending</option>
        <option value="Rejected">Rejected</option>
      </select>
    </div>

    <div class="table-wrap">
      <table class="table-lg" id="leave-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Employee</th>
            <th>Leave Type</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Days</th>
            <th>Reason</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% leaves.forEach((l, i) => { %>
          <tr data-status="<%= l.status %>">
            <td style="color:var(--n80);"><%= i + 1 %></td>
            <td style="font-weight:500;"><%= l.employee_name %></td>
            <td><%= l.leave_type %></td>
            <td class="text-muted"><%= l.start_date %></td>
            <td class="text-muted"><%= l.end_date %></td>
            <td style="text-align:center;"><%= l.days %></td>
            <td class="text-muted" style="max-width:200px;"><%= l.reason %></td>
            <td>
              <span class="badge <%=
                l.status === 'Approved' ? 'badge-success' :
                l.status === 'Pending'  ? 'badge-warning' : 'badge-danger'
              %>"><%= l.status %></span>
            </td>
            <td>
              <div class="actions-col">
                <% if (l.status === 'Pending') { %>
                <form action="/leave/<%= l.id %>/approve" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-sm btn-success">Approve</button>
                </form>
                <form action="/leave/<%= l.id %>/reject" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-sm btn-danger">Reject</button>
                </form>
                <% } %>
                <form id="del-leave-<%= l.id %>" action="/leave/<%= l.id %>?_method=DELETE" method="POST" style="display:inline;">
                  <button type="button" class="btn btn-sm" style="background:var(--n20);color:var(--n80);" onclick="confirmDelete('del-leave-<%= l.id %>')">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
                  </button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
          <% if (leaves.length === 0) { %>
          <tr><td colspan="9" style="text-align:center;color:var(--n80);padding:32px;">No leave requests found.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <div class="pagination">
      <span>Showing <%= leaves.length %> records</span>
    </div>
  </div>
</div>

<!-- Add Leave Modal -->
<div class="modal-overlay" id="modal-add-leave">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">File Leave Request</div>
      <button class="modal-close" onclick="closeModal('modal-add-leave')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form action="/leave" method="POST">
      <div class="modal-body">
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Employee *</label>
            <select class="form-input form-select" name="employee_id" required style="background-position:right 8px center;">
              <% employees.forEach(e => { %>
              <option value="<%= e.id %>" data-name="<%= e.name %>"><%= e.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Leave Type *</label>
            <select class="form-input form-select" name="leave_type" required style="background-position:right 8px center;">
              <option>Sick Leave</option>
              <option>Vacation Leave</option>
              <option>Emergency Leave</option>
              <option>Maternity Leave</option>
              <option>Paternity Leave</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Start Date *</label>
            <input class="form-input" type="date" name="start_date" required>
          </div>
          <div class="form-group">
            <label class="form-label">End Date *</label>
            <input class="form-input" type="date" name="end_date" required>
          </div>
          <div class="form-group">
            <label class="form-label">Number of Days</label>
            <input class="form-input" type="number" name="days" min="1" value="1">
          </div>
          <div class="form-group full">
            <label class="form-label">Reason</label>
            <textarea class="form-input" name="reason" placeholder="Briefly describe your reason…"></textarea>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('modal-add-leave')">Cancel</button>
        <button type="submit" class="btn btn-primary">Submit Request</button>
      </div>
    </form>
  </div>
</div>

<script>
function filterLeaveStatus(v) {
  document.querySelectorAll('#leave-table tbody tr').forEach(row => {
    row.style.display = (!v || row.dataset.status === v) ? '' : 'none';
  });
}
</script>

<%- include('partials/footer') %>
