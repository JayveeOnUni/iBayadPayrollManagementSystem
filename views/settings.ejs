<%- include('partials/header', { title: 'Settings', activeMenu: 'settings', activePage: activeTab }) %>

<div class="page-header">
  <h1 class="page-title">Setting</h1>
  <div class="page-actions">
    <button class="btn btn-primary" form="settings-form" type="submit">Save Changes</button>
  </div>
</div>

<div class="content-section">
  <div class="tabs">
    <a href="/settings/general"    class="tab-btn <%= activeTab === 'settings-general'    ? 'active' : '' %>">General</a>
    <a href="/settings/leave"      class="tab-btn <%= activeTab === 'settings-leave'      ? 'active' : '' %>">Leave</a>
    <a href="/settings/attendance" class="tab-btn <%= activeTab === 'settings-attendance' ? 'active' : '' %>">Attendance</a>
    <a href="/settings/payroll"    class="tab-btn <%= activeTab === 'settings-payroll'    ? 'active' : '' %>">Payroll</a>
  </div>

  <div class="card" style="padding:28px 32px;">
    <form id="settings-form" action="/settings/<%= tab %>" method="POST">

      <% if (tab === 'general') { %>
      <div style="max-width:560px;display:flex;flex-direction:column;gap:20px;">
        <div class="form-group">
          <label class="form-label">Company Name</label>
          <input class="form-input" name="company_name" value="IBayad Inc." placeholder="Your company name">
        </div>
        <div class="form-group">
          <label class="form-label">Company Email</label>
          <input class="form-input" type="email" name="company_email" value="hr@ibayad.com">
        </div>
        <div class="form-group">
          <label class="form-label">Timezone</label>
          <select class="form-input form-select" name="timezone" style="background-position:right 8px center;">
            <option value="Asia/Manila" selected>Asia/Manila (UTC+8)</option>
            <option value="UTC">UTC</option>
            <option value="America/New_York">America/New_York (UTC-5)</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Default Language</label>
          <select class="form-input form-select" name="language" style="background-position:right 8px center;">
            <option value="en" selected>English</option>
            <option value="fil">Filipino</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Work Days per Week</label>
          <input class="form-input" type="number" name="work_days" value="5" min="1" max="7">
        </div>
      </div>

      <% } else if (tab === 'leave') { %>
      <div style="max-width:560px;display:flex;flex-direction:column;gap:20px;">
        <div class="form-group">
          <label class="form-label">Annual Leave Allowance (days)</label>
          <input class="form-input" type="number" name="leave_allowance" value="15" min="0">
        </div>
        <div class="form-group">
          <label class="form-label">Sick Leave Allowance (days)</label>
          <input class="form-input" type="number" name="sick_allowance" value="10" min="0">
        </div>
        <div class="form-group">
          <label class="form-label">Leave Approval Mode</label>
          <select class="form-input form-select" name="leave_approval" style="background-position:right 8px center;">
            <option value="manager">Manager Approval</option>
            <option value="hr">HR Approval</option>
            <option value="auto">Auto-Approve</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Minimum Days Notice for Vacation Leave</label>
          <input class="form-input" type="number" name="leave_notice_days" value="3" min="0">
        </div>
        <div style="display:flex;align-items:center;gap:10px;padding:12px 0;">
          <input type="checkbox" id="carry_over" name="carry_over" style="width:16px;height:16px;cursor:pointer;" checked>
          <label for="carry_over" style="font-size:14px;font-weight:500;color:var(--n90);cursor:pointer;">Allow carry-over of unused leave</label>
        </div>
      </div>

      <% } else if (tab === 'attendance') { %>
      <div style="max-width:560px;display:flex;flex-direction:column;gap:20px;">
        <div class="form-group">
          <label class="form-label">Default Work Start Time</label>
          <input class="form-input" type="time" name="work_start" value="08:00">
        </div>
        <div class="form-group">
          <label class="form-label">Default Work End Time</label>
          <input class="form-input" type="time" name="work_end" value="17:00">
        </div>
        <div class="form-group">
          <label class="form-label">Grace Period for Late (minutes)</label>
          <input class="form-input" type="number" name="grace_period" value="15" min="0">
        </div>
        <div class="form-group">
          <label class="form-label">Overtime Rate Multiplier</label>
          <input class="form-input" type="number" name="ot_rate" value="1.25" step="0.05" min="1">
        </div>
        <div style="display:flex;align-items:center;gap:10px;padding:12px 0;">
          <input type="checkbox" id="half_day" name="half_day" style="width:16px;height:16px;cursor:pointer;" checked>
          <label for="half_day" style="font-size:14px;font-weight:500;color:var(--n90);cursor:pointer;">Allow half-day leave requests</label>
        </div>
      </div>

      <% } else if (tab === 'payroll') { %>
      <div style="max-width:560px;display:flex;flex-direction:column;gap:20px;">
        <div class="form-group">
          <label class="form-label">Payroll Currency</label>
          <select class="form-input form-select" name="currency" style="background-position:right 8px center;">
            <option value="PHP" selected>PHP — Philippine Peso</option>
            <option value="USD">USD — US Dollar</option>
            <option value="EUR">EUR — Euro</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Payroll Period</label>
          <select class="form-input form-select" name="payroll_period" style="background-position:right 8px center;">
            <option value="semi-monthly" selected>Semi-monthly (1st & 15th)</option>
            <option value="monthly">Monthly</option>
            <option value="weekly">Weekly</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">SSS Contribution (%)</label>
          <input class="form-input" type="number" name="sss" value="4.5" step="0.1" min="0">
        </div>
        <div class="form-group">
          <label class="form-label">PhilHealth Contribution (%)</label>
          <input class="form-input" type="number" name="philhealth" value="2.0" step="0.1" min="0">
        </div>
        <div class="form-group">
          <label class="form-label">Pag-IBIG Contribution (%)</label>
          <input class="form-input" type="number" name="pagibig" value="2.0" step="0.1" min="0">
        </div>
      </div>
      <% } %>

    </form>
  </div>
</div>

<%- include('partials/footer') %>
