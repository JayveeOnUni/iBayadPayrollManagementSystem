<%- include('partials/header', { title: 'Shift', activeMenu: 'administration', activePage: 'admin-shift' }) %>

<div class="page-header">
  <h1 class="page-title">Administration</h1>
  <div class="page-actions">
    <button class="btn btn-primary" onclick="openModal('modal-add')">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add Shift
    </button>
  </div>
</div>

<div class="content-section">
  <div class="tabs">
    <a href="/administration/roles"        class="tab-btn">Roles</a>
    <a href="/administration/shift"        class="tab-btn active">Shift</a>
    <a href="/administration/department"   class="tab-btn">Department</a>
    <a href="/administration/holiday"      class="tab-btn">Holiday</a>
    <a href="/administration/announcement" class="tab-btn">Announcement</a>
  </div>

  <div class="card" style="padding:20px 24px;">
    <div class="table-wrap">
      <table class="table-lg">
        <thead>
          <tr><th>#</th><th>Shift Name</th><th>Time In</th><th>Time Out</th><th>Break (min)</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% shifts.forEach((s, i) => { %>
          <tr>
            <td style="color:var(--n80);"><%= i+1 %></td>
            <td style="font-weight:500;"><%= s.name %></td>
            <td><%= s.time_in %></td>
            <td><%= s.time_out %></td>
            <td style="text-align:center;"><%= s.break_duration %></td>
            <td>
              <div class="actions-col">
                <button class="btn btn-outline btn-sm" onclick='editShift(<%= JSON.stringify(s) %>)'>Edit</button>
                <form id="del-shift-<%= s.id %>" action="/administration/shift/<%= s.id %>?_method=DELETE" method="POST" style="display:inline;">
                  <button type="button" class="btn btn-sm" style="background:var(--danger-surface);color:var(--danger-main);" onclick="confirmDelete('del-shift-<%= s.id %>')">Delete</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="modal-overlay" id="modal-add">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Add Shift</div>
      <button class="modal-close" onclick="closeModal('modal-add')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form action="/administration/shift" method="POST">
      <div class="modal-body">
        <div class="form-grid">
          <div class="form-group full">
            <label class="form-label">Shift Name *</label>
            <input class="form-input" name="name" required placeholder="e.g. Morning Shift">
          </div>
          <div class="form-group">
            <label class="form-label">Time In</label>
            <input class="form-input" type="time" name="time_in" value="08:00">
          </div>
          <div class="form-group">
            <label class="form-label">Time Out</label>
            <input class="form-input" type="time" name="time_out" value="17:00">
          </div>
          <div class="form-group">
            <label class="form-label">Break Duration (min)</label>
            <input class="form-input" type="number" name="break_duration" value="60" min="0">
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('modal-add')">Cancel</button>
        <button type="submit" class="btn btn-primary">Save</button>
      </div>
    </form>
  </div>
</div>

<div class="modal-overlay" id="modal-edit">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Edit Shift</div>
      <button class="modal-close" onclick="closeModal('modal-edit')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <form id="edit-form" action="" method="POST">
      <input type="hidden" name="_method" value="PUT">
      <div class="modal-body">
        <div class="form-grid">
          <div class="form-group full">
            <label class="form-label">Shift Name *</label>
            <input class="form-input" name="name" id="edit-name" required>
          </div>
          <div class="form-group">
            <label class="form-label">Time In</label>
            <input class="form-input" type="time" name="time_in" id="edit-ti">
          </div>
          <div class="form-group">
            <label class="form-label">Time Out</label>
            <input class="form-input" type="time" name="time_out" id="edit-to">
          </div>
          <div class="form-group">
            <label class="form-label">Break Duration (min)</label>
            <input class="form-input" type="number" name="break_duration" id="edit-break">
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('modal-edit')">Cancel</button>
        <button type="submit" class="btn btn-primary">Update</button>
      </div>
    </form>
  </div>
</div>

<script>
function editShift(s) {
  document.getElementById('edit-form').action = '/administration/shift/' + s.id;
  document.getElementById('edit-name').value  = s.name;
  document.getElementById('edit-ti').value    = s.time_in || '';
  document.getElementById('edit-to').value    = s.time_out || '';
  document.getElementById('edit-break').value = s.break_duration || 60;
  openModal('modal-edit');
}
</script>

<%- include('partials/footer') %>
